#Область ПрограммныйИнтерфейс

// Начало. hw_11_2.Гамберг — программное размещение полей на формах документов
Процедура ДоработатьФормуДокумента(Форма) Экспорт

	ИмяФормы = Форма.ИмяФормы;

	ФормыСКонтактнымЛицом = Новый Массив;
	ФормыСКонтактнымЛицом.Добавить("Документ.ЗаказПокупателя.Форма.ФормаДокумента");
	ФормыСКонтактнымЛицом.Добавить("Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента");
	ФормыСКонтактнымЛицом.Добавить("Документ.ПоступлениеТоваровУслуг.Форма.ФормаДокумента");
	ФормыСКонтактнымЛицом.Добавить("Документ.ОплатаПоставщику.Форма.ФормаДокумента");
	ФормыСКонтактнымЛицом.Добавить("Документ.ОплатаОтПокупателя.Форма.ФормаДокумента");

	Если ФормыСКонтактнымЛицом.Найти(ИмяФормы) <> Неопределено Тогда
		hw_11_2_ДобавитьПолеКонтактноеЛицо(Форма);
	КонецЕсли;

	Если ИмяФормы = "Документ.ЗаказПокупателя.Форма.ФормаДокумента" Тогда
		hw_11_2_ДобавитьСкидкуИКнопкуЗаказПокупателя(Форма);
	КонецЕсли;

КонецПроцедуры
// Конец. hw_11_2.Гамберг

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура hw_11_2_ДобавитьПолеКонтактноеЛицо(Форма)

	Если Форма.Элементы.Найти("hw_11_2_КонтактноеЛицо") <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	ЭлементДоговор = Форма.Элементы.Найти("Договор");
	Если ЭлементДоговор = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Родитель = ЭлементДоговор.Родитель;
	ПодчиненныеЭлементы = Родитель.ПодчиненныеЭлементы;
	Индекс = ПодчиненныеЭлементы.Индекс(ЭлементДоговор);
	ВставитьПеред = Неопределено;
	Если Индекс < ПодчиненныеЭлементы.Количество() - 1 Тогда
		ВставитьПеред = ПодчиненныеЭлементы.Получить(Индекс + 1);
	КонецЕсли;

	Поле = Форма.Элементы.Добавить("hw_11_2_КонтактноеЛицо", Тип("ПолеФормы"), Родитель);
	Если ВставитьПеред <> Неопределено Тогда
		Форма.Элементы.Переместить(Поле, Родитель, ВставитьПеред);
	КонецЕсли;
	Поле.Вид = ВидПоляФормы.ПолеВвода;
	Поле.ПутьКДанным = "Объект.КонтактноеЛицо";
	Поле.Заголовок = "Контактное лицо";

КонецПроцедуры

Процедура hw_11_2_ДобавитьСкидкуИКнопкуЗаказПокупателя(Форма)

	Если Форма.Элементы.Найти("hw_11_2_СогласованнаяСкидка") <> Неопределено
		И Форма.Элементы.Найти("hw_11_2_КнопкаПересчитатьПоСкидке") <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	Якорь = Форма.Элементы.Найти("hw_11_2_КонтактноеЛицо");
	Если Якорь = Неопределено Тогда
		Якорь = Форма.Элементы.Найти("Договор");
	КонецЕсли;
	Если Якорь = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Родитель = Якорь.Родитель;
	ПодчиненныеЭлементы = Родитель.ПодчиненныеЭлементы;
	Индекс = ПодчиненныеЭлементы.Индекс(Якорь);
	ВставитьПеред = Неопределено;
	Если Индекс < ПодчиненныеЭлементы.Количество() - 1 Тогда
		ВставитьПеред = ПодчиненныеЭлементы.Получить(Индекс + 1);
	КонецЕсли;

	Если Форма.Элементы.Найти("hw_11_2_СогласованнаяСкидка") = Неопределено Тогда
		ПолеСкидки = Форма.Элементы.Добавить("hw_11_2_СогласованнаяСкидка", Тип("ПолеФормы"), Родитель);
		Если ВставитьПеред <> Неопределено Тогда
			Форма.Элементы.Переместить(ПолеСкидки, Родитель, ВставитьПеред);
		КонецЕсли;
		ПолеСкидки.Вид = ВидПоляФормы.ПолеВвода;
		ПолеСкидки.ПутьКДанным = "Объект.СогласованнаяСкидка";
		ПолеСкидки.Заголовок = "Согласованная скидка";
		ПолеСкидки.УстановитьДействие("ПриИзменении", "hw_11_2_СогласованнаяСкидкаПриИзменении");
	КонецЕсли;

	Если Форма.Команды.Найти("hw_11_2_ПересчитатьТаблицыПоСкидке") = Неопределено Тогда
		Команда = Форма.Команды.Добавить("hw_11_2_ПересчитатьТаблицыПоСкидке");
		Команда.Действие = "hw_11_2_ПересчитатьТаблицыПоСкидке";
		Команда.Заголовок = "Пересчитать таблицы";
		Команда.ИзменяетСохраняемыеДанные = Ложь;
	КонецЕсли;

	Если Форма.Элементы.Найти("hw_11_2_КнопкаПересчитатьПоСкидке") = Неопределено Тогда
		ЯкорьСкидки = Форма.Элементы.Найти("hw_11_2_СогласованнаяСкидка");
		Если ЯкорьСкидки = Неопределено Тогда
			Возврат;
		КонецЕсли;
		РодительКнопки = ЯкорьСкидки.Родитель;
		ПодчКнопки = РодительКнопки.ПодчиненныеЭлементы;
		ИндексК = ПодчКнопки.Индекс(ЯкорьСкидки);
		ВставитьПередК = Неопределено;
		Если ИндексК < ПодчКнопки.Количество() - 1 Тогда
			ВставитьПередК = ПодчКнопки.Получить(ИндексК + 1);
		КонецЕсли;
		Кнопка = Форма.Элементы.Добавить("hw_11_2_КнопкаПересчитатьПоСкидке", Тип("КнопкаФормы"), РодительКнопки);
		Если ВставитьПередК <> Неопределено Тогда
			Форма.Элементы.Переместить(Кнопка, РодительКнопки, ВставитьПередК);
		КонецЕсли;
		Кнопка.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
		Кнопка.ИмяКоманды = "hw_11_2_ПересчитатьТаблицыПоСкидке";
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
